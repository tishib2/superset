# Devin API 認証情報
# app.devin.ai → Settings → API Keys で取得
DEVIN_API_KEY=cog_xxxx
DEVIN_ORG_ID=org-xxxx

# Slack Incoming Webhook URL
# api.slack.com/apps → アプリ選択 → Incoming Webhooks で取得
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxx/xxxx/xxxx

# GitHub コンテキスト（ローカル実行時に手動設定）
GITHUB_ACTOR=your-github-username
GITHUB_SERVER_URL=https://github.com
GITHUB_REPOSITORY=your-org/superset
GITHUB_SHA=abc1234

# DRY_RUN=1 にすると API 呼び出し・Slack 通知をスキップしてログのみ出力
# DRY_RUN=1
